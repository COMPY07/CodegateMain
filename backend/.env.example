# ---- LLM providers (server-side only; never returned to the browser) ----
# Anthropic (Claude) — powers the "claude" chat model. Leave blank to use the fake provider.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# OpenAI (GPT) — powers the "gpt" chat model AND the security red-team step below.
# 여기에 키를 넣으세요.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ---- Security engine (Increment 2) ----
# The sa-redteam C++ scanner runs in deterministic "fake" mode (no network) for
# authoritative file:line findings. The adversarial LLM red-team step runs in the
# backend against OpenAI using REDTEAM_MODEL (needs OPENAI_API_KEY above).
# secure_agent analysis 브랜치를 빌드한 바이너리의 절대 경로를 권장합니다.
SA_REDTEAM_BIN=../secure_agent/build/sa-redteam
SA_REDTEAM_TIMEOUT_S=300
REDTEAM_MODEL=gpt-4o
SECURITY_MAX_LLM_PROBES=12

# ---- filesystem guard (Increment 3, BE-001) ----
# Managed project root. When set, /api/scan project_root must live inside it.
WORKSPACE_ROOT=../workspace

# ---- server ----
PORT=55555
CORS_ORIGINS=http://localhost:5180,http://127.0.0.1:5180
