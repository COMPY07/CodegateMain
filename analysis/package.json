{
  "name": "vibegate",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r --workspace-concurrency=1 build",
    "gen:schema": "pnpm --filter @vibegate/contracts gen:schema",
    "check:schema": "pnpm --filter @vibegate/contracts check:schema",
    "check:contracts": "pnpm --filter @vibegate/contracts check:types",
    "lint": "eslint packages/*/src --ext .ts",
    "test": "pnpm -r test",
    "verify": "pnpm check:contracts && pnpm build && pnpm check:schema && pnpm lint && pnpm test"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
